{
  "expo": {
    "name": "Stevia Care",
    "slug": "stevia-care",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#14532D"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.steviacare.app",
      "infoPlist": {
        "NSCameraUsageDescription": "To capture lab reports and prescriptions",
        "NSPhotoLibraryUsageDescription": "To upload lab reports and prescriptions"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#14532D"
      },
      "package": "com.steviacare.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.VIBRATE",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.VIBRATE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Stevia Care to access your photos."
        }
      ],
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "5c3b0ef4-e6e5-40ab-8247-04f12db4572c"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/5c3b0ef4-e6e5-40ab-8247-04f12db4572c"
    }
  }
}
