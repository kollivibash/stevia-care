{
  "expo": {
    "name": "Stevia Care",
    "slug": "stevia-care",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#14532D"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.steviacare.app",
      "infoPlist": {
        "NSCameraUsageDescription": "To capture lab reports and prescriptions",
        "NSPhotoLibraryUsageDescription": "To upload lab reports and prescriptions"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#14532D"
      },
      "package": "com.steviacare.app",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "VIBRATE"
      ]
    },
    "plugins": [
      "expo-secure-store",
      ["expo-image-picker", {"photosPermission": "Allow Stevia Care to access your photos."}],
      ["expo-document-picker", {"iCloudContainerEnvironment": "Production"}],
      "expo-updates"
    ],
    "updates": {
      "url": "https://u.expo.dev/YOUR_PROJECT_ID",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "eas": {
        "projectId": "YOUR_PROJECT_ID"
      }
    }
  }
}
